{
  "name": "tailwind-plus-commit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "npm run start:local",
    "start:local": "npm run db:ensure && vite --mode development",
    "start:remote": "vite",
    "build": "tsc && vite build",
    "build:github": "NODE_ENV=production tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "clean": "rm -rf node_modules && rm -rf dist && rm -rf .vite package-lock.json",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:status": "supabase status",
    "db:migrate": "echo '❌ BLOCKED: This command could deploy to remote Supabase!' && echo 'Use: npm run db:reset (for local development)' && exit 1",
    "db:migrate:local": "supabase db reset",
    "db:diff": "supabase db diff",
    "db:generate": "supabase gen types typescript --local > src/core/types/database.types.ts",
    "db:studio": "supabase studio",
    "db:logs": "supabase logs",
    "db:ensure": "supabase status || supabase start",
    "db:clear-analytics": "./scripts/clear-analytics.sh",
    "update-supabase-keys": "./scripts/update-supabase-keys.sh",
    "cms:migrate": "tsx scripts/migrate-content.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "test:unit": "vitest run --reporter=verbose",
    "test:integration": "npm run db:reset && vitest run --reporter=verbose --testNamePattern='integration'",
    "test:schemas": "vitest run --reporter=verbose src/admin/cms/assets/schemas/__tests__/asset.schemas.test.ts src/admin/system/sites/schemas/__tests__/site.schemas.test.ts src/public/analytics/schemas/__tests__/edge-functions.schemas.test.ts src/public/cms/schemas/__tests__/menu.edge-functions.schemas.test.ts src/public/cms/schemas/__tests__/page.edge-functions.schemas.test.ts",
    "test:services": "vitest run --reporter=verbose --testNamePattern='services'",
    "test:hooks": "vitest run --reporter=verbose --testNamePattern='hooks'",
    "test:edge-functions": "vitest run --reporter=verbose --testNamePattern='edge-functions'",
    "test:admin": "vitest run --reporter=verbose --testNamePattern='admin'",
    "test:public": "vitest run --reporter=verbose --testNamePattern='public'",
    "test:core": "vitest run --reporter=verbose --testNamePattern='core'",
    "test:cms": "vitest run --reporter=verbose --testNamePattern='cms'",
    "test:analytics": "vitest run --reporter=verbose --testNamePattern='analytics'",
    "test:leads": "vitest run --reporter=verbose --testNamePattern='leads'",
    "test:system": "vitest run --reporter=verbose --testNamePattern='system'",
    "test:all": "npm run test:unit && npm run test:integration",
    "test:ci": "npm run db:reset && npm run test:all"
  },
  "browserslist": "defaults, not ie <= 11",
  "dependencies": {
    "@mdi/js": "^7.4.47",
    "@mdi/react": "^1.6.1",
    "@reduxjs/toolkit": "^2.9.0",
    "@supabase/supabase-js": "^2.45.4",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.90.5",
    "browser-image-compression": "^2.0.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "motion": "^10.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.28.0",
    "recharts": "^3.2.1",
    "remark-gfm": "^4.0.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.1.0",
    "@types/react": "^18.3.26",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "eslint": "^9.37.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "jsdom": "^27.0.1",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.8.3",
    "vite": "^5.1.0",
    "vitest": "^3.2.4"
  }
}
